# ─────────────────────────────────────────────────────────────
# Keystatic — Cloud Storage Mode (production + staging)
# ─────────────────────────────────────────────────────────────
# Keystatic Cloud handles authentication via keystatic.cloud.
# No OAuth app or secrets needed.
#
# Setup steps:
# 1. Create account at https://keystatic.cloud
# 2. Create team: eos-club
# 3. Create project: eosclub
# 4. Link project to GitHub repo: wunluv/eosclub
# 5. Add Primary URLs in project settings:
#      - https://staging.prod.khanyi.com
#      - https://eos-club.de
# 6. Enable "Allow local development" for local dev

# ─────────────────────────────────────────────────────────────
# Email capture (Google Apps Script endpoint)
# ─────────────────────────────────────────────────────────────
PUBLIC_GAS_ENDPOINT=

# ─────────────────────────────────────────────────────────────
# Site URL — used for canonical / OG tags
# ─────────────────────────────────────────────────────────────
# Staging:
PUBLIC_SITE_URL=https://staging.prod.khanyi.com
# Production:
# PUBLIC_SITE_URL=https://eos-club.de

# ─────────────────────────────────────────────────────────────
# Node environment (set in deploy scripts — do not change here)
# ─────────────────────────────────────────────────────────────
# NODE_ENV=production
