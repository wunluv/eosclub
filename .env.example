# ─────────────────────────────────────────────────────────────
# Keystatic — GitHub Storage Mode (production + staging)
# ─────────────────────────────────────────────────────────────
# Create a GitHub OAuth App per environment:
#
#   STAGING  OAuth App:
#     Homepage URL:            https://staging.prod.khanyi.com
#     Authorization callback:  https://staging.prod.khanyi.com/api/keystatic/github/callback
#
#   PRODUCTION OAuth App:
#     Homepage URL:            https://eos-club.de
#     Authorization callback:  https://eos-club.de/api/keystatic/github/callback
#
# These are *example* values — replace with real credentials.
# Never commit real secrets to version control.

KEYSTATIC_GITHUB_CLIENT_ID=Iv23liMIgc557nhlcJru
KEYSTATIC_GITHUB_CLIENT_SECRET=<your_github_oauth_client_secret>
KEYSTATIC_SECRET=<random_32+_char_string>
PUBLIC_GITHUB_REPO=wunluv/eosclub

# ─────────────────────────────────────────────────────────────
# Email capture (Google Apps Script endpoint)
# ─────────────────────────────────────────────────────────────
PUBLIC_GAS_ENDPOINT=

# ─────────────────────────────────────────────────────────────
# Site URL — used for canonical / OG tags
# ─────────────────────────────────────────────────────────────
# Staging:
# PUBLIC_SITE_URL=https://staging.prod.khanyi.com
# Production:
PUBLIC_SITE_URL=https://eos-club.de

# ─────────────────────────────────────────────────────────────
# Node environment (set in deploy scripts — do not change here)
# ─────────────────────────────────────────────────────────────
# NODE_ENV=production
